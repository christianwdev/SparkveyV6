{
  "extends": "../base.tsconfig.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "types": [ "bun", "node" ],
    "paths": {
      "*": [ "./*" ],
      "@utils/*": [ "./utils/*" ],
      "@hooks/*": [ "./app/_hooks/*" ],
      "@contexts/*": [ "./app/_contexts/*" ],
      "@constants/*": [ "./constants/*" ],
      "@styles/*": [ "./app/_styles/*" ],
      "@components/*": [
        "./app/_components/*",
        "./app/_loadingComponents/*"
      ],
      "@layouts/*": [
        "./app/_layouts/*"
      ],
      "@public/*": [
        "./public/*"
      ],
      "types/*": [
        "./types/*",
        "../types/*",
        "../_discord/types/*"
      ],
      "@i18n/*": [
        "./i18n/*"
      ]
    }
  },
  "include": [
    "jsx.declarations.d.ts",
    "svg.d.ts",
    "unplugin-icons.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "@types/bun"
  ]
}
