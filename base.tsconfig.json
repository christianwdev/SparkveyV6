{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": false,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "incremental": true,
    "types": [ "bun", "node" ],
    "paths": {
      "*": [ "./*" ],
      "types/*": [
        "./types/*",
        "./src/types/*"
      ]
    }
  }
}
